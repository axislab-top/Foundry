# 日志基础设施环境变量配置
# 复制此文件到 .env 并根据需要修改

# ==================== ELK 栈配置 ====================

# Elasticsearch
ELASTICSEARCH_PORT=9200
ELASTICSEARCH_TRANSPORT_PORT=9300

# Logstash
LOGSTASH_BEATS_PORT=5044
LOGSTASH_HTTP_PORT=8080
LOGSTASH_TCP_PORT=5000

# Kibana
KIBANA_PORT=5601
KIBANA_ELASTICSEARCH_USERNAME=
KIBANA_ELASTICSEARCH_PASSWORD=

# ==================== Loki 栈配置 ====================

# Loki
LOKI_PORT=3100

# Promtail
PROMTAIL_PORT=9080

# Grafana
GRAFANA_PORT=3000
GRAFANA_ADMIN_USER=admin
GRAFANA_ADMIN_PASSWORD=admin

# ==================== 通用配置 ====================

# 日志保留期（小时）
# 默认值：168（7天）
# 此值会应用到 Loki 配置中的 retention_period 和 reject_old_samples_max_age
# 格式：数字（小时数），例如：168 表示 7 天，720 表示 30 天
LOG_RETENTION_HOURS=168

# 日志存储路径（相对于项目根目录）
LOG_STORAGE_PATH=../../infrastructure/logging/logs

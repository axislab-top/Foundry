# Redis Environment Variables
# Copy this file to .env and update with your actual values

# Redis Configuration
REDIS_PORT=6379
REDIS_PASSWORD=

# Redis Connection Settings (for scripts and applications)
REDIS_HOST=localhost
REDIS_URL=redis://${REDIS_HOST}:${REDIS_PORT}

# Redis Connection with Password (if set)
# REDIS_URL=redis://:${REDIS_PASSWORD}@${REDIS_HOST}:${REDIS_PORT}

# Data Directory (for Docker Compose on Windows)
# Use absolute paths if relative paths cause mount issues
# Example for Windows: REDIS_DATA_DIR=D:/Service/infrastructure/redis/data
# Leave unset to use relative paths (../../infrastructure/redis/data)
# REDIS_DATA_DIR=../../infrastructure/redis/data

# Backup Configuration
REDIS_BACKUP_DIR=./data
REDIS_BACKUP_RETENTION_DAYS=7

# Monitoring Configuration
REDIS_MONITOR_ENABLED=true
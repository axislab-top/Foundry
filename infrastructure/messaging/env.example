# RabbitMQ 环境变量配置示例

# 默认用户
RABBITMQ_USER=admin
RABBITMQ_PASSWORD=admin123

# 虚拟主机
RABBITMQ_VHOST=/

# 端口配置
RABBITMQ_PORT=5672
RABBITMQ_MANAGEMENT_PORT=15672

# 连接配置
RABBITMQ_HOST=localhost
RABBITMQ_URI=amqp://admin:admin123@localhost:5672/

# 队列配置
RABBITMQ_PREFETCH_COUNT=10
RABBITMQ_QUEUE_DURABLE=true
RABBITMQ_QUEUE_EXCLUSIVE=false
RABBITMQ_QUEUE_AUTO_DELETE=false

# 交换器配置
RABBITMQ_EXCHANGE_TYPE=topic
RABBITMQ_EXCHANGE_DURABLE=true
RABBITMQ_EXCHANGE_AUTO_DELETE=false

# 重试配置
RABBITMQ_MAX_RETRIES=3
RABBITMQ_RETRY_DELAY=1000

# 健康检查
RABBITMQ_HEALTH_CHECK_ENABLED=true
RABBITMQ_HEALTH_CHECK_INTERVAL=30000
































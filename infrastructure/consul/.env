# Consul 环境变量配置示例
# 复制此文件为 .env 并根据需要修改

# Consul 端口配置
CONSUL_PORT=8500
CONSUL_DNS_PORT=8600
CONSUL_GRPC_PORT=8502

# Consul 数据中心配置
CONSUL_DATACENTER=dc1
CONSUL_DOMAIN=consul

# Consul UI 配置
CONSUL_UI=true

# ACL 配置（生产环境建议启用）
CONSUL_ACL_ENABLE=false
CONSUL_ACL_DEFAULT_POLICY=allow

# 开发模式（单节点，适合开发环境）
CONSUL_DEV_MODE=true

# 生产环境配置（多节点集群）
# CONSUL_BOOTSTRAP_EXPECT=3
# CONSUL_RETRY_JOIN=consul1:8301,consul2:8301,consul3:8301
# CONSUL_ENCRYPT=your-encryption-key

# 日志级别
CONSUL_LOG_LEVEL=INFO

# 服务注册配置（用于应用服务）
SERVICE_NAME=gateway-service
SERVICE_ADDRESS=localhost
SERVICE_VERSION=1.0.0

# Consul 连接配置（用于应用服务）
CONSUL_ENABLED=true
CONSUL_HOST=localhost
CONSUL_TOKEN=
CONSUL_CONFIG_PREFIX=config/

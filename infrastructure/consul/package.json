{
  "name": "@service/consul",
  "version": "1.0.0",
  "description": "Consul 服务发现、配置管理和健康检查模块",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "default": "./dist/index.js"
    },
    "./package.json": "./package.json"
  },
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch",
    "clean": "rimraf dist",
    "test": "node -e \"process.exit(0)\""
  },
  "keywords": [
    "consul",
    "service-discovery",
    "service-registry",
    "health-check",
    "configuration",
    "microservices"

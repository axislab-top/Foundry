  "dependencies": {
    "consul": "^1.2.0",
    "@service/config": "workspace:*"
  },
  "devDependencies": {
    "@types/node": "^20.10.0",
    "@types/consul": "^2.0.0",
    "typescript": "^5.3.3"
  },
  "files": [
    "dist",
    "src"
  ]

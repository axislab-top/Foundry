{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "node",
    "lib": ["ES2022"],
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "resolveJsonModule": true,
    "allowSyntheticDefaultImports": true,
    "baseUrl": ".",
    "paths": {
      "typeorm": ["../../migrations/node_modules/typeorm"]
    },
    "typeRoots": [
      "../../../node_modules/@types",
      "../../migrations/node_modules/@types"
    ]
  },
  "include": ["**/*.ts"],
  "exclude": ["node_modules"]
}


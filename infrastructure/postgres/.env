# PostgreSQL Environment Variables
# Copy this file to .env and update with your actual values

# ==================== Docker Compose 配置 ====================
# 这些变量用于 Docker Compose 启动 PostgreSQL 容器
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_DB=service_db
POSTGRES_PORT=5432
POSTGRES_HOST=localhost

# ==================== 应用程序配置 ====================
# 这些变量用于应用程序和迁移工具连接数据库
# migrations 工具会优先使用 DB_* 变量，如果没有则回退到 POSTGRES_* 变量
DB_HOST=localhost
DB_PORT=5432
DB_USERNAME=postgres
DB_PASSWORD=postgres
DB_DATABASE=service_db

# ==================== 路径配置 (Windows Docker Compose) ====================
# Use absolute paths if relative paths cause mount issues
# Example for Windows: POSTGRES_DATA_DIR=D:/Service/infrastructure/postgres/data
# Leave unset to use relative paths (../../infrastructure/postgres/data)
# POSTGRES_DATA_DIR=../../infrastructure/postgres/data
# POSTGRES_CONFIG_DIR=../../infrastructure/postgres/config
# POSTGRES_INIT_DIR=../../infrastructure/postgres/init-scripts
# POSTGRES_BACKUP_DIR=../../infrastructure/postgres/backups

# ==================== 连接字符串 ====================
DATABASE_URL=postgresql://${POSTGRES_USER}:${POSTGRES_PASSWORD}@${POSTGRES_HOST}:${POSTGRES_PORT}/${POSTGRES_DB}



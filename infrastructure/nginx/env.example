# Nginx 负载均衡器环境变量配置示例
# 复制此文件为 .env 并根据实际情况修改

# Nginx HTTP 端口（默认: 80）
NGINX_HTTP_PORT=80

# Nginx HTTPS 端口（默认: 443）
NGINX_HTTPS_PORT=443

# 时区设置
TZ=Asia/Shanghai

# Nginx 环境（development/production）
NGINX_ENV=development

# Gateway 服务配置
# Gateway 服务名称（Docker 网络中的服务名）
GATEWAY_SERVICE_NAME=gateway-service

# Gateway 服务端口
GATEWAY_SERVICE_PORT=3002

# Gateway 服务实例数量（用于动态配置）
GATEWAY_INSTANCES=1

# SSL 配置（如果启用 HTTPS）
# SSL 证书路径（容器内路径）
SSL_CERT_PATH=/etc/nginx/ssl/cert.pem
SSL_KEY_PATH=/etc/nginx/ssl/key.pem

# 域名配置（用于 SSL 证书）
DOMAIN_NAME=api.example.com

# 日志级别（debug/info/notice/warn/error）
NGINX_LOG_LEVEL=warn

# 是否启用访问日志
NGINX_ACCESS_LOG=true

# 是否启用详细日志格式
NGINX_DETAILED_LOG=false
































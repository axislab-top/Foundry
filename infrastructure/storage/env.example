# MinIO 对象存储环境变量配置示例
# 复制此文件为 .env 并根据实际情况修改

# MinIO API 端口（默认: 9000）
MINIO_PORT=9000

# MinIO Console 端口（默认: 9001）
MINIO_CONSOLE_PORT=9001

# MinIO 根用户（默认: minioadmin）
MINIO_ROOT_USER=minioadmin

# MinIO 根密码（默认: minioadmin）
# 生产环境必须修改为强密码
MINIO_ROOT_PASSWORD=minioadmin

# 时区设置
TZ=Asia/Shanghai
































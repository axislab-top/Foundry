# Environment variables (仅忽略根目录的 .env，基础设施的 .env 使用安全默认值可提交)
/.env
/.env.local
/.env.shared
/.env.*.local

# PostgreSQL data directory (contains database files)
infrastructure/postgres/data/

# PostgreSQL backups (optional - you may want to version control these)
# infrastructure/postgres/backups/*.sql.gz

# Logs
*.log
infrastructure/postgres/config/log/
infrastructure/logging/logs/
infrastructure/logging/.env

# OS files
.DS_Store
Thumbs.db

# IDE
.vscode/
.idea/
*.swp
*.swo

# Claude Code worktrees
.claude/worktrees/

# Vendored third-party content (e.g. agency-agents import)
vendor/agency-agents/
vendor/agency-agents-zh/

# Node modules
node_modules/

# Build outputs
dist/
build/
*.tsbuildinfo

# Turborepo cache
.turbo/

# Understand-Anything analysis
.understand-anything/

# SSL certificates and private keys
*.pem
*.key
*.cert
*.p12
*.pfx
*.keystore
!infrastructure/nginx/ssl/.gitkeep
!infrastructure/nginx/ssl/README.md

# Test credentials and secrets
scripts/.e2e-run-creds.json
**/cypress/fixtures/creds.json

# Vite cache
.vite/

# Coverage reports
coverage/

# Development-only scripts (not for production)
scripts/e2e-*.mjs
scripts/benchmark-*.mjs
scripts/diagnose-*.mjs
scripts/ci-local.mjs

# Load testing tools
tools/loadtests/

# Misc
*.tgz
*.tar.gz

# Local reference documents (not for GitHub)
更新.md
同步上传.md
push规划.md

# 主群「战略 → 编排 → 部门执行 → 监督」主链推荐环境变量（Worker）
# 用法：合并到 apps/worker/.env 或通过部署环境注入。
# 完整模板见仓库根 env.shared.example；产品说明见 Foundry-员工执行与产出闭环-后续计划.md §六。

# --- 跨服务 Redis（生产必配）---
# API 读草稿、Worker 写草稿须同一库；见 docs/deployment/collaboration-main-chain-baseline.md
# 与 env.shared 中 COLLAB_REDIS_URL 保持一致
COLLAB_REDIS_URL=redis://localhost:6379/0
REDIS_DB_COLLAB=0

# --- Phase 0：主链观测（推荐） ---
# Collaboration Program SSOT（主群交付诉求生命周期；默认开启）
COLLAB_PROGRAM_SSOT_ENABLED=true
# brief 齐后：auto=直接 planning；always=停 pending_confirm 待用户确认
COLLAB_PROGRAM_CONFIRM_MODE=auto
# Program 启用后不再回退旧 post-intent router（回滚时可设 true）
COLLAB_PROGRAM_LEGACY_ROUTER_FALLBACK=false
# CEO Turn Tool-First：单回合 tool loop + collaboration.orchestrate 唯一派发副作用（回滚可设 false）
COLLAB_TURN_TOOL_ORCHESTRATION_ENABLED=true
# Markdown Dispatch Plan → Compiler → auto flush（预发/灰度建议 true；回滚见 docs/deployment/dispatch-plan-v2-rollout-sop.md）
COLLAB_CEO_DISPATCH_PLAN_V2_ENABLED=true
# Dispatch Plan 编译成功后：auto=立即下发；confirm=待用户确认再 flush
COLLAB_DISPATCH_CONFIRM_MODE=auto
# Phase 2：主群 goal_lock 监督强制 HTTP 内联（默认 true）
COLLAB_MAIN_ROOM_FORCE_INLINE_SUPERVISION=true
MAIN_ROOM_DISPATCH_CHAT_MESSAGES_ENABLED=true
MAIN_ROOM_DISPATCH_RESPECT_DEPENDENCIES=true
# --- 部门群对话模式（真实公司群聊；默认不向聊天写系统镜像）---
COLLAB_DEPT_CHAT_CONVERSATIONAL_MODE=true
# 以下默认 false；逐项 true 可恢复旧「全镜像」行为
# COLLAB_DEPT_TASK_STAGE_CHAT_ENABLED=false
# COLLAB_DEPT_SKILL_TOOL_CALL_CHAT_ENABLED=false
# COLLAB_DEPT_SUPERVISION_REPORT_IN_ROOM_ENABLED=false
# COLLAB_DEPT_DISPATCH_SYSTEM_CARD_ENABLED=false
# COLLAB_DEPT_EMPLOYEE_COLLAB_ACK_CHAT_ENABLED=false

# --- 主群降噪（对话优先时可关波次 nudge）---
MAIN_ROOM_DISPATCH_WAVE_SUPERVISION_NUDGE_ENABLED=false

# --- Phase 4：产出体验与富交互（预发/本地 E2E 建议开启）---
MAIN_ROOM_DISTRIBUTION_COMPLETION_SUMMARY_ENABLED=true
MAIN_ROOM_REPLAY_PATCH_STRATEGY_DRAFT_FROM_SUMMARY_ENABLED=true
# deliverable_bias：task_publish / 文档类输入使用交付物导向 Strategy 检索后缀
# STRATEGY_PLANNING_PROFILE_MODE=deliverable_bias

# --- 部门群总监 LLM 对话（默认 true；关闭后仍可通过 forceModelPath 走真回复，仅灰度降本）---
COLLAB_DEPT_DIRECTOR_MODEL_ENABLED=true
COLLAB_DEPT_DIRECT_REPLY_MAX_OUTPUT_TOKENS=4096
COLLAB_DEPT_DIRECT_REPLY_STREAMING_ENABLED=true
COLLAB_DIRECT_REPLY_LENGTH_CONTINUATION_MAX_ROUNDS=2

# --- Phase 3：部门内拆工与员工自主（预发/本地 E2E 建议开启）---
DIRECTOR_AUTONOMOUS_ENABLED=true
EMPLOYEE_AUTONOMOUS_ENABLED=true
MULTI_AGENT_GRAPH_V2_ENABLED=true
# 监督层读主管部门汇报（须与上三项同时为 true 才生效）
COLLAB_SUPERVISION_INPUT_MODE=dept_reports
# L2 自动结案前须存在可下载交付物（file_assets / artifact）；false 回滚旧行为
COLLAB_L2_AUTO_COMPLETE_REQUIRE_DELIVERABLE=true
# 依赖续派前要求主管部门 readyForSupervision 汇报
COLLAB_DISPATCH_REQUIRE_DIRECTOR_DEPT_REPORT=true
# 公司级灰度：100% 或白名单（与 runtime_preferences.l1 / PHASE1_ROLLOUT 对齐）
PHASE1_ROLLOUT_PERCENT=100
# 可选：ACP 出站事件总线（本计划主路径用直连 MQ 消费者，不强制）
# AUTONOMOUS_EVENT_BUS_V2_ENABLED=true

# --- 治理 ---
COLLAB_ASSIGNMENT_VALIDATOR_ENABLED=true
COLLAB_ASSIGNABLE_DEPARTMENT_POLICY=org_only

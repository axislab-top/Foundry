{
  "name": "Service",
  "version": "1.0.0",
  "description": "NestJS Microservices Platform",
  "main": "index.js",
  "scripts": {
    "setup:dev": "node -e \"fs.copyFileSync('env.shared.example','.env.shared')\" && pnpm install && node scripts/env-manager.js && node scripts/pull-docker-images.js && pnpm infra:start && node scripts/bootstrap-db.js && pnpm dev",
    "setup:quick": "node -e \"fs.copyFileSync('env.shared.example','.env.shared')\" && pnpm install && node scripts/env-manager.js && node scripts/pull-docker-images.js && pnpm infra:start && node scripts/bootstrap-db.js",
    "bootstrap:db": "node scripts/bootstrap-db.js",
    "build": "turbo run build",
    "dev": "turbo run dev --concurrency=32",
    "start": "turbo run start",
    "test": "turbo run test",
    "test:critical-path": "pnpm --filter @service/worker run test:critical-path",
    "test:pact": "pnpm --filter @service/api run test:pact",
    "ci:local": "node scripts/ci-local.mjs",
    "lint": "turbo run lint",
    "infra:start": "docker-compose -f deployment/docker/docker-compose.yml -f deployment/docker/docker-compose.dev.yml up -d",
    "infra:stop": "docker-compose -f deployment/docker/docker-compose.yml -f deployment/docker/docker-compose.dev.yml down",
    "infra:restart": "docker-compose -f deployment/docker/docker-compose.yml -f deployment/docker/docker-compose.dev.yml restart",
    "infra:status": "docker-compose -f deployment/docker/docker-compose.yml -f deployment/docker/docker-compose.dev.yml ps",
    "infra:logs": "docker-compose -f deployment/docker/docker-compose.yml -f deployment/docker/docker-compose.dev.yml logs -f",
    "infra:prod:start": "docker-compose -f deployment/docker/docker-compose.yml -f deployment/docker/docker-compose.prod.yml up -d",
    "infra:prod:stop": "docker-compose -f deployment/docker/docker-compose.yml -f deployment/docker/docker-compose.prod.yml down",
    "infra:test:start": "docker-compose -f deployment/docker/docker-compose.yml -f deployment/docker/docker-compose.test.yml up -d",
    "infra:test:stop": "docker-compose -f deployment/docker/docker-compose.yml -f deployment/docker/docker-compose.test.yml down",
    "start:all": "pnpm infra:start",
    "start:dev": "pnpm infra:start",
    "start:dev:local": "pnpm infra:start && timeout /t 10 /nobreak >nul && pnpm dev",
    "start:prod": "pnpm infra:prod:start && pnpm build && pnpm start",
    "stop:all": "pnpm infra:stop",
    "stop:dev:local": "taskkill /F /IM node.exe /FI \"WINDOWTITLE eq *turbo*\" 2>nul || exit 0",
    "clean": "turbo run clean",
    "clean:all": "pnpm clean && docker-compose -f deployment/docker/docker-compose.yml down -v",
    "migrate:show": "cd infrastructure/migrations && pnpm run migrate:show",
    "migrate:run": "cd infrastructure/migrations && pnpm run migrate:run",
    "migrate:revert": "cd infrastructure/migrations && pnpm run migrate:revert",
    "migrate:generate": "typeorm migration:generate",
    "e2e:company-wizard": "node scripts/e2e-company-wizard.mjs",
    "e2e:main-journey": "node scripts/e2e-main-journey.mjs",
    "e2e:main-room-chain": "node scripts/e2e-main-room-full-chain-probe.mjs",
    "e2e:phase3-department-chain": "node scripts/e2e-phase3-department-chain-probe.mjs",
    "e2e:phase4-output-experience": "node scripts/e2e-phase4-output-experience-probe.mjs",
    "diagnose:user-path": "node scripts/diagnose-foundry-user-path.mjs",
    "benchmark:ceo-llm": "node scripts/benchmark-ceo-breakdown-llm.mjs",
    "llm:smoke-db": "pnpm --filter @service/api run llm:smoke-db",
    "e2e:collaboration": "node scripts/e2e-collaboration-login-flow.mjs",
    "e2e:collaboration:journey": "node scripts/e2e-collaboration-user-journey.mjs",
    "docs:collab-llm-io-report": "node scripts/collab-llm-io-jsonl-to-md.mjs",
    "e2e:acp": "pnpm exec tsx scripts/test-acp-end-to-end.ts",
    "import:agency-agents": "pnpm --filter @service/api run import:agency-agents",
    "sync:agency-names-zh": "pnpm --filter @service/api run sync:agency-names-zh",
    "red-team:sandbox": "node scripts/red-team-sandbox-scenarios.mjs",
    "red-team:sandbox:real": "node scripts/red-team-sandbox-scenarios.mjs --real",
    "generate:departments": "pnpm exec tsx scripts/generate-departments.ts",
    "test:phase1-e2e": "pnpm --filter @service/worker exec npx jest -c ../../jest.config.js --testPathPattern=phase1-predictive-graph-autonomous",
    "test:w9-director-e2e": "pnpm --filter @service/worker exec npx jest -c ../../jest.config.js --testPathPattern=director-autonomous",
    "test:w10-employee-e2e": "pnpm --filter @service/worker exec npx jest -c ../../jest.config.js --testPathPattern=employee-autonomous",
    "test:phase2-e2e": "pnpm --filter @service/worker exec npx jest -c ../../jest.config.js --runTestsByPath ../../test/e2e/cross-department.e2e-spec.ts ../../test/e2e/phase2-full-autonomous.e2e-spec.ts",
    "test:phase3-rollout-e2e": "pnpm --filter @service/worker exec npx jest -c ../../jest.config.js --runTestsByPath ../../test/e2e/phase3-full-rollout.e2e-spec.ts",
    "test:main-room-staging-walkthrough": "pnpm --filter @service/worker exec npx jest -c ../../jest.config.js --runTestsByPath ../../test/e2e/main-room-staging-walkthrough.e2e-spec.ts ../../test/e2e/main-room-governance-loop.e2e-spec.ts",
    "checklist:phase3-rollout": "bash scripts/phase3-rollout-checklist.sh"
  },
  "keywords": [
    "nestjs",
    "microservices"
  ],
  "author": "",
  "license": "ISC",
  "packageManager": "pnpm@10.28.0",
  "devDependencies": {
    "@types/jest": "^30.0.0",
    "@types/node": "^20.19.27",
    "rimraf": "^6.1.2",
    "tsx": "^4.19.2",
    "turbo": "^2.7.3",
    "typescript": "^5.9.3"
  },
  "dependencies": {
    "axios": "^1.13.2"
  }
}

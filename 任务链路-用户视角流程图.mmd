%% 任务链路：完整示意图（与 apps/api TasksService + gateway + client 实现对齐）
%% 渲染：VS Code Mermaid / GitHub / mmdc
%% 配套说明与代码核对表：任务链路-用户视角说明.md

flowchart TB
  subgraph ui["前端 client/src/features"]
    direction TB
    uiTC["tasks/page.tsx\n任务中心：新建任务"]
    uiDrawer["tasks/TaskDetailDrawer.tsx\n下发到部门群 / 主群汇总回报"]
    uiCollab["collaboration/chats/page.tsx\n主群与部门群对话\n部门侧栏含说明文案"]
  end

  subgraph gw["网关 apps/gateway routes.config.ts"]
    direction TB
    gwCreate["POST /v1/tasks\ntasks.create"]
    gwDispatch["POST /v1/tasks/:id/chat/dispatch\ntasks.chat.dispatchToDepartment"]
    gwReport["POST /v1/tasks/:id/chat/report\ntasks.chat.reportToMain"]
    gwCoord["POST /v1/tasks/:id/chat/coordination-request\ntasks.chat.requestCoordination"]
    gwProg["PATCH /v1/tasks/:id/progress\ntasks.updateProgress"]
  end

  subgraph api["API apps/api TasksService"]
    direction TB
    fnCreate["create()"]
    fnDispatch["dispatchTaskToDepartmentRoom()"]
    fnReport["reportTaskToMainRoom()"]
    fnCoord["requestTaskCoordination()"]
    fnProg["updateProgress()"]
  end

  subgraph auto["自动化 / 内部（与人类入口并行）"]
    direction TB
    wCEO["DirectorManagementFacade\ndelegateFromCeo()"]
    wCreate["create(... trustedInternal)\n含指派 Director Agent"]
    wOrch["Worker Autonomous 等\nRPC tasks.create"]
    mqCreated["MQ task.created"]
    evtExtract["CollaborationTaskExtracted\nListener → createFromEvent()\n无人类 actor"]
  end

  subgraph db["持久化与群消息"]
    direction TB
    tblTasks[("tasks 表")]
    deptMsg["部门群 collaboration_messages\nrichCard department_dispatch\n+ execution 线程 metadata")]
    mainMsg["主群 collaboration_messages\n正文前缀 部门汇总·任务回报\nrichCard report_summary"]
  end

  uiTC --> gwCreate --> fnCreate
  uiDrawer --> gwDispatch --> fnDispatch
  uiDrawer --> gwReport --> fnReport
  uiDrawer --> gwProg --> fnProg
  uiCollab -.->|可选：跨部门协同\n当前 client 未封装此 API| gwCoord

  fnCreate --> tblTasks
  fnCreate --> mqCreated
  fnDispatch --> tblTasks
  fnDispatch --> deptMsg
  fnReport --> mainMsg
  gwCoord --> fnCoord
  fnCoord --> mainMsg

  wCEO --> wCreate
  wCreate --> fnCreate
  wOrch --> fnCreate
  fnFromEvent["createFromEvent()\n无 Actor / 内部租户上下文"]
  evtExtract --> fnFromEvent --> tblTasks

  subgraph chkCreate["create 权限摘要"]
    direction TB
    c1["assertMember"]
    c2["privileged = isAdminActor\n或 Owner/Admin 成员"]
    c3["否则 assertMemberSelfService\n仅 unassigned 等"]
  end
  fnCreate --> c1

  subgraph chkDispatch["dispatch 权限摘要"]
    direction TB
    d1["assertMember"]
    d2["assertActiveRoomMember\n部门群"]
    d3["可选 fromRoomId\n同校验"]
  end
  fnDispatch --> d1

  subgraph chkReport["report 权限摘要"]
    direction TB
    r1["assertMember"]
    r2["assertActiveRoomMember\n主群"]
    r3["可选 sourceRoomId\n同校验"]
    r4["仅 isAdminActor\n或 hasCompanyOwnerOrAdminMembership"]
  end
  fnReport --> r1

  subgraph chkCoord["coordination 权限摘要"]
    direction TB
    co1["assertMember"]
    co2["assertActiveRoomMember 主群"]
    co3["目标 roomType=department\n主群发 richCard\ncoordination_request"]
  end
  fnCoord --> co1

  subgraph chkProg["progress 权限摘要"]
    direction LR
    p1["assertCanUpdateProgress\nAdmin / Owner-Admin / 任务创建人\nreview 态另校验 approvalId"]
  end
  fnProg --> p1

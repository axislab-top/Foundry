# 腾讯云生产 — 在 deployment/docker/.env 基础上追加/覆盖
# 由 scripts/cloud-deploy/prepare-env.ps1 生成为 deployment/cloud/tencent-lighthouse/.env

NODE_ENV=production
FOUNDRY_IMAGE_PREFIX=foundry
FOUNDRY_IMAGE_TAG=latest

# 公网域名（构建 nginx 镜像与运行时 CORS 须一致）
VITE_PUBLIC_ORIGIN=https://axislab.top
CORS_ORIGIN=https://axislab.top
GRAFANA_ROOT_URL=https://axislab.top/ops/grafana/

DB_LOGGING=false
LOG_LEVEL=warn

# Docker 内服务发现
DB_HOST=postgres
DB_SYNCHRONIZE=false
DB_LOGGING=false
TEST_AUTH_ENABLED=false
SWAGGER_ENABLED=false

# 协作 Redis 与 API/Worker 同库
COLLAB_REDIS_URL=redis://redis:6379/0
REDIS_HOST=redis

# 微信/OAuth 回调（按实际在微信开放平台配置）
WECHAT_REDIRECT_URI=https://axislab.top/api/auth/wechat/callback

# ⚠️ 以下密钥须与本机 deployment/docker/.env 保持一致（迁移已有数据）
# JWT_SECRET=
# JWT_REFRESH_SECRET=
# AES_KEY=
# DB_PASSWORD=
# RABBITMQ_PASSWORD=

# 注册邮箱验证码（QQ 邮箱 SMTP 授权码会轮换，更新后需同步到服务器并 recreate api-service）
# SMTP_HOST=smtp.qq.com
# SMTP_PORT=465
# SMTP_SECURE=true
# SMTP_USER=3900971531@qq.com
# SMTP_PASS=
# SMTP_FROM=3900971531@qq.com
# REGISTER_EMAIL_VERIFICATION_ENABLED=true
# MAIL_DEV_LOG_ONLY=false

# Docker Compose 环境变量配置
# 生成时间: 2026-01-07T22:14:39.286Z

# ==================== 应用配置 ====================
NODE_ENV=development

# ==================== JWT 配置 ====================
JWT_SECRET=your-jwt-secret-key-here-change-in-production
JWT_REFRESH_SECRET=your-jwt-refresh-secret-key-here-change-in-production
JWT_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

# ==================== 数据库配置 ====================
DB_HOST=postgres
DB_PORT=5432
DB_USERNAME=postgres
DB_PASSWORD=postgres

# 默认数据库（用于API和Webhooks服务）
DB_DATABASE=service_db

# Gateway服务专用数据库
GATEWAY_DB_DATABASE=gateway_db

# Webhooks服务数据库（默认与DB_DATABASE相同）
# WEBHOOKS_DB_DATABASE=service_db

DB_SYNCHRONIZE=true
DB_LOGGING=false

# ==================== Redis 配置 ====================
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_DB=0

# ==================== 加密配置 ====================
ENCRYPTION_ADAPTER=aes
AES_KEY=your-32-byte-base64-encoded-key-here
AES_ALGORITHM=aes-256-gcm
AES_KEY_LENGTH=32

# ==================== 哈希配置 ====================
HASHING_ADAPTER=bcrypt
BCRYPT_SALT_ROUNDS=10

# ==================== CORS 配置 ====================
CORS_ORIGIN=*
CORS_CREDENTIALS=true

# ==================== 监控配置 ====================
METRICS_ADAPTER=prometheus
METRICS_ENABLED=true

# ==================== Swagger 配置 ====================
SWAGGER_ENABLED=true
SWAGGER_PATH=api-docs

# ==================== 服务端口 ====================
API_SERVICE_PORT=3000
GATEWAY_SERVICE_PORT=3002
WEBHOOKS_SERVICE_PORT=3003
WORKER_SERVICE_PORT=3004
LOGGING_SERVICE_PORT=3001

# ==================== RabbitMQ 配置 ====================
RABBITMQ_HOST=rabbitmq
RABBITMQ_PORT=5672
RABBITMQ_USER=guest
RABBITMQ_PASSWORD=guest
RABBITMQ_VHOST=/

# ==================== Consul 配置 ====================
CONSUL_ENABLED=false
CONSUL_HOST=consul
CONSUL_PORT=8500

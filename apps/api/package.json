{
  "name": "@service/api",
  "version": "1.0.0",
  "description": "API Service - NestJS Application",
  "main": "dist/main.js",
  "scripts": {
    "build": "nest build",
    "format": "prettier --write \"src/**/*.ts\" \"test/**/*.ts\"",
    "start": "nest start",
    "dev": "nest start --watch",
    "start:debug": "nest start --debug --watch",
    "start:prod": "node dist/main",
    "lint": "eslint \"{src,apps,libs,test}/**/*.ts\" --fix",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:cov": "jest --coverage",
    "test:debug": "node --inspect-brk -r tsconfig-paths/register -r ts-node/register node_modules/.bin/jest --runInBand",
    "test:e2e": "jest --config ./test/jest-e2e.json",
    "clean": "rimraf dist",
    "migration:generate": "cd ../../infrastructure/migrations && pnpm migrate migration:generate",
    "migration:run": "cd ../../infrastructure/migrations && pnpm migrate migration:run",
    "migration:revert": "cd ../../infrastructure/migrations && pnpm migrate migration:revert",
    "migration:show": "cd ../../infrastructure/migrations && pnpm migrate migration:show"
  },
  "keywords": ["api", "nestjs", "microservice"],
  "author": "",
  "license": "ISC",
  "packageManager": "pnpm@10.27.0",
  "dependencies": {
    "@nestjs/swagger": "^7.4.2",
    "@contracts/types": "workspace:*",
    "@contracts/events": "workspace:*",
    "@service/messaging": "workspace:*",
    "@nestjs/common": "^10.3.0",
    "@nestjs/core": "^10.3.0",
    "@nestjs/config": "^3.1.1",
    "@nestjs/microservices": "^10.3.0",
    "@nestjs/platform-express": "^10.3.0",
    "@nestjs/typeorm": "^10.0.2",
    "amqplib": "^0.10.3",
    "express": "^4.18.2",
    "@service/cache": "workspace:*",
    "@service/config": "workspace:*",
    "@service/logging": "workspace:*",
    "@service/monitoring": "workspace:*",
    "@service/security": "workspace:*",
    "class-transformer": "^0.5.1",
    "class-validator": "^0.14.0",
    "joi": "^17.13.3",
    "pg": "^8.11.3",
    "reflect-metadata": "^0.1.13",
    "rxjs": "^7.8.1",
    "typeorm": "^0.3.17",
    "minio": "^7.1.3",
    "@aws-sdk/client-s3": "^3.490.0",
    "@aws-sdk/s3-request-presigner": "^3.490.0",
    "ali-oss": "^6.20.0"
  },
  "devDependencies": {
    "@nestjs/cli": "^10.2.10",
    "@nestjs/schematics": "^10.0.3",
    "@nestjs/testing": "^10.3.0",
    "@types/express": "^4.17.21",
    "@types/node": "^20.10.0",
    "@types/pg": "^8.10.9",
    "@typescript-eslint/eslint-plugin": "^6.19.0",
    "@typescript-eslint/parser": "^6.19.0",
    "eslint": "^8.56.0",
    "eslint-config-prettier": "^9.1.0",
    "eslint-plugin-prettier": "^5.1.3",
    "jest": "^29.7.0",
    "prettier": "^3.1.1",
    "source-map-support": "^0.5.21",
    "@swc/cli": "^0.1.62",
    "@swc/core": "^1.3.92",
    "ts-jest": "^29.1.1",
    "ts-loader": "^9.5.1",
    "ts-node": "^10.9.2",
    "tsconfig-paths": "^4.2.0",
    "typescript": "^5.3.3"
  }
}

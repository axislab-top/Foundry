{
  "name": "@service/api",
  "version": "1.0.0",
  "description": "API Service - NestJS Application",
  "type": "module",
  "main": "dist/main.js",
  "scripts": {
    "build": "nest build",
    "format": "prettier --write \"src/**/*.ts\" \"test/**/*.ts\"",
    "start": "nest start",
    "dev": "nest start --watch",
    "start:debug": "nest start --debug --watch",
    "start:prod": "node dist/main",
    "lint": "eslint \"{src,apps,libs,test}/**/*.ts\" --fix",
    "test": "jest --config ./jest.config.cjs",
    "test:watch": "jest --config ./jest.config.cjs --watch",
    "test:cov": "jest --config ./jest.config.cjs --coverage",
    "test:debug": "node --inspect-brk -r tsconfig-paths/register -r ts-node/register node_modules/.bin/jest --config ./jest.config.cjs --runInBand",
    "test:e2e": "jest --config ./test/jest-e2e.json",
    "test:pact": "jest --config ./jest.pact.config.cjs",
    "pact:generate": "cross-env PACT_GENERATE=1 jest --config ./jest.pact.config.cjs test/pact/generate-consumer-pact.spec.ts",
    "clean": "rimraf dist",
    "migration:generate": "cd ../../infrastructure/migrations && pnpm run migrate:generate",
    "migration:run": "cd ../../infrastructure/migrations && pnpm run migrate:run",
    "migration:revert": "cd ../../infrastructure/migrations && pnpm run migrate:revert",
    "migration:show": "cd ../../infrastructure/migrations && pnpm run migrate:show",
    "import:agency-agents": "node scripts/import-agency-agents.mjs",
    "sync:agency-names-zh": "node scripts/sync-agency-agent-names-zh.mjs"
  },
  "keywords": [
    "api",
    "nestjs",
    "microservice"
  ],
  "author": "",
  "license": "ISC",
  "packageManager": "pnpm@10.27.0",
  "dependencies": {
    "@aws-sdk/client-s3": "^3.490.0",
    "@aws-sdk/s3-request-presigner": "^3.490.0",
    "@clickhouse/client": "1.8.0",
    "@contracts/events": "workspace:*",
    "@contracts/types": "workspace:*",
    "@foundry/task-core": "workspace:*",
    "@foundry/supervisor-core": "workspace:*",
    "@foundry/observability-core": "workspace:*",
    "@temporalio/client": "^1.11.7",
    "@nestjs/common": "^10.3.0",
    "@nestjs/config": "^3.1.1",
    "@nestjs/core": "^10.3.0",
    "@nestjs/microservices": "^10.3.0",
    "@nestjs/platform-express": "^10.3.0",
    "@nestjs/swagger": "^7.4.2",
    "@nestjs/typeorm": "^10.0.2",
    "@service/cache": "workspace:*",
    "@service/config": "workspace:*",
    "@service/logging": "workspace:*",
    "@service/messaging": "workspace:*",
    "@service/monitoring": "workspace:*",
    "@service/security": "workspace:*",
    "@service/tenant": "workspace:*",
    "adm-zip": "^0.5.16",
    "ali-oss": "^6.20.0",
    "amqplib": "^0.10.3",
    "class-transformer": "^0.5.1",
    "class-validator": "^0.14.0",
    "express": "^4.18.2",
    "gray-matter": "^4.0.3",
    "joi": "^17.13.3",
    "minio": "^7.1.3",
    "pdf-parse": "^2.4.5",
    "pg": "^8.11.3",
    "redis": "^4.7.0",
    "reflect-metadata": "^0.1.13",
    "rxjs": "^7.8.1",
    "typeorm": "^0.3.17"
  },
  "devDependencies": {
    "@nestjs/cli": "^10.2.10",
    "@nestjs/schematics": "^10.0.3",
    "@nestjs/testing": "^10.3.0",
    "@pact-foundation/pact": "^13.2.0",
    "@swc/cli": "^0.1.62",
    "@swc/core": "^1.3.92",
    "@types/express": "^4.17.21",
    "@types/multer": "^1.4.12",
    "@types/node": "^20.10.0",
    "@types/pdf-parse": "^1.1.5",
    "@types/pg": "^8.10.9",
    "@typescript-eslint/eslint-plugin": "^6.19.0",
    "@typescript-eslint/parser": "^6.19.0",
    "cross-env": "^10.1.0",
    "eslint": "^8.56.0",
    "eslint-config-prettier": "^9.1.0",
    "eslint-plugin-prettier": "^5.1.3",
    "jest": "^29.7.0",
    "prettier": "^3.1.1",
    "source-map-support": "^0.5.21",
    "ts-jest": "^29.1.1",
    "ts-loader": "^9.5.1",
    "ts-node": "^10.9.2",
    "tsconfig-paths": "^4.2.0",
    "typescript": "^5.3.3"
  }
}

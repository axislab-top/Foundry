    "@nestjs/typeorm": "^10.0.2",
    "@opentelemetry/api": "^1.9.1",
    "@service/ai": "workspace:*",
    "@service/cache": "workspace:*",
    "@service/config": "workspace:*",
    "@service/logging": "workspace:*",
    "@service/messaging": "workspace:*",
    "@service/monitoring": "workspace:*",
    "@service/security": "workspace:*",
    "@service/tenant": "workspace:*",
    "@temporalio/client": "^1.11.7",
    "adm-zip": "^0.5.16",
    "ali-oss": "^6.20.0",
    "amqplib": "^0.10.3",
    "class-transformer": "^0.5.1",
    "class-validator": "^0.14.0",
    "cron-parser": "^5.5.0",
    "express": "^4.18.2",
    "gray-matter": "^4.0.3",
    "joi": "^17.13.3",
    "minio": "^7.1.3",
    "nodemailer": "^8.0.10",
    "pdf-parse": "^2.4.5",

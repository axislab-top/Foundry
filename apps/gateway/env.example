# Gateway Service 环境变量配置
# 复制此文件到 .env 并根据需要修改
# 
# 注意：
# - 本地开发：在 apps/gateway 目录下创建 .env 文件
# - Docker 部署：在 deployment/docker 目录下创建 .env 文件（推荐）

# ==================== 应用配置 ====================

# 运行环境
NODE_ENV=development

# 服务端口
PORT=3002

# ==================== JWT 配置 ====================

# JWT 访问令牌密钥（生产环境必须使用强密钥）
JWT_SECRET=your-secret-key-change-in-production

# JWT 访问令牌过期时间
# 格式：数字+单位（s=秒, m=分钟, h=小时, d=天）
# 例如：15m 表示 15 分钟，1h 表示 1 小时，7d 表示 7 天
JWT_EXPIRES_IN=15m

# JWT 刷新令牌密钥（生产环境必须使用强密钥）
JWT_REFRESH_SECRET=your-refresh-secret-key-change-in-production

# JWT 刷新令牌过期时间
JWT_REFRESH_EXPIRES_IN=7d

# ==================== 数据库配置 ====================

# 数据库主机地址
# 本地开发：localhost
# Docker 环境：postgres（服务名）
DB_HOST=localhost

# 数据库端口
DB_PORT=5432

# 数据库用户名
DB_USERNAME=postgres

# 数据库密码
DB_PASSWORD=postgres

# 数据库名称
DB_DATABASE=gateway_db

# 是否自动同步数据库结构（生产环境应设为 false）
# true: 自动创建/更新表结构（仅用于开发）
# false: 使用迁移文件管理数据库结构（推荐生产环境）
DB_SYNCHRONIZE=false

# 是否启用数据库查询日志
DB_LOGGING=false

# ==================== 监控配置 ====================

# 监控适配器类型（prometheus, statsd, console, noop）
METRICS_ADAPTER=prometheus

# 是否启用默认收集器
METRICS_ENABLE_DEFAULT_COLLECTORS=true

# Prometheus 是否收集默认指标
PROMETHEUS_COLLECT_DEFAULT_METRICS=true

# Prometheus 指标前缀（可选）
# PROMETHEUS_PREFIX=gateway

# ==================== Redis 配置 ====================
# 
# 注意：Redis 服务本身的配置在 infrastructure/redis/ 中
# 这里只配置网关服务作为客户端连接 Redis 的参数
# 
# 建议：在 deployment/docker/.env 中统一管理 Redis 连接配置，
#       各个服务引用相同的配置，避免重复定义

# Redis 主机地址
# 本地开发：localhost
# Docker 环境：redis（服务名，与 infrastructure/redis/docker-compose.yml 中的服务名一致）
# 建议从 infrastructure/redis/env.example 中获取
REDIS_HOST=localhost

# Redis 端口
# 建议从 infrastructure/redis/env.example 中获取
REDIS_PORT=6379

# Redis 密码（如果 Redis 服务设置了密码）
# 建议从 infrastructure/redis/env.example 中获取
REDIS_PASSWORD=

# Redis 数据库编号（网关服务使用的数据库）
# 注意：不同服务可以使用不同的数据库编号，避免数据冲突
REDIS_DB=0

# Redis 连接 URL（可选，如果设置了此值，会优先使用）
# 格式：redis://[:password@]host[:port][/db]
# REDIS_URL=redis://localhost:6379

# ==================== 服务地址配置 ====================

# API 服务地址
# 本地开发：http://localhost:3000
# Docker 环境：http://api-service:3000（使用服务名）
API_SERVICE_URL=http://localhost:3000

# Webhooks 服务地址
WEBHOOKS_SERVICE_URL=http://localhost:3003

# Worker 服务地址
WORKER_SERVICE_URL=http://localhost:3004

# Logging 服务地址
LOGGING_SERVICE_URL=http://localhost:3001

# ==================== 限流配置 ====================

# 限流时间窗口（秒）
RATE_LIMIT_TTL=60

# 最大请求数（在时间窗口内）
RATE_LIMIT_MAX_REQUESTS=100

# 是否跳过成功请求的限流计数
# true: 只有失败的请求才计入限流
# false: 所有请求都计入限流
RATE_LIMIT_SKIP_SUCCESSFUL_REQUESTS=false

# ==================== HTTP 配置 ====================

# HTTP 请求超时时间（毫秒）
HTTP_TIMEOUT=30000

# ==================== 断路器配置 ====================

# 是否启用断路器
# true: 启用断路器，防止级联故障
# false: 禁用断路器
CIRCUIT_BREAKER_ENABLED=true

# 失败阈值（超过此值打开断路器）
# 例如：5 表示连续 5 次失败后打开断路器
CIRCUIT_BREAKER_FAILURE_THRESHOLD=5

# 半开状态下的成功阈值
# 例如：2 表示半开状态下连续 2 次成功后关闭断路器
CIRCUIT_BREAKER_SUCCESS_THRESHOLD=2

# 超时时间（毫秒）
# 超过此时间后尝试恢复（从打开状态进入半开状态）
CIRCUIT_BREAKER_TIMEOUT=60000

# 重置超时（毫秒）
# 打开状态持续此时间后进入半开状态
CIRCUIT_BREAKER_RESET_TIMEOUT=30000

# ==================== CORS 配置 ====================

# CORS 允许的来源
# 开发环境：*（允许所有来源）
# 生产环境：具体域名，例如：https://example.com,https://www.example.com
CORS_ORIGIN=*

# CORS 是否允许携带凭证（cookies, authorization headers）
CORS_CREDENTIALS=true

# ==================== 微信登录配置 ====================

# 微信开放平台 AppID
WECHAT_APP_ID=

# 微信开放平台 AppSecret
WECHAT_APP_SECRET=

# 微信登录回调地址
# 开发环境：http://localhost:3002/api/auth/wechat/callback
# 生产环境：https://your-domain.com/api/auth/wechat/callback
WECHAT_REDIRECT_URI=http://localhost:3002/api/auth/wechat/callback

# 微信授权范围（通常使用 snsapi_login）
WECHAT_SCOPE=snsapi_login

# 前端 URL（用于登录成功后重定向）
# 开发环境：http://localhost:3000
# 生产环境：https://your-frontend-domain.com
FRONTEND_URL=http://localhost:3000

# ==================== Swagger 配置 ====================

# 是否启用 Swagger 文档（默认: true，生产环境建议设置为 false）
SWAGGER_ENABLED=true

# Swagger UI 路径（默认: api-docs）
SWAGGER_PATH=api-docs

# ==================== 加密配置 ====================
# 
# 注意：加密功能是可选的。如果不配置加密密钥，应用仍可正常启动，
#      但加密功能将不可用（EncryptionService 会记录警告日志）
# 
# 方式一：使用 AES 加密（推荐，简单快速）
# 生成 32 字节（256 位）的 AES 密钥：
#   - Linux/Mac: openssl rand -base64 32
#   - Windows PowerShell: [Convert]::ToBase64String((1..32 | ForEach-Object { Get-Random -Minimum 0 -Maximum 256 }))
#   - Node.js: require('crypto').randomBytes(32).toString('base64')
# 
# AES 加密密钥（32 字节，Base64 编码）
# 例如：AES_KEY=your-32-byte-base64-encoded-key-here
AES_KEY=>REDACTED_AES_KEY=

# AES 加密算法（默认: aes-256-gcm）
# 可选值：aes-256-gcm, aes-192-gcm, aes-128-gcm
AES_ALGORITHM=aes-256-gcm

# AES 密钥长度（字节，默认: 32）
# 注意：必须与密钥实际长度匹配
# 32 = AES-256, 24 = AES-192, 16 = AES-128
AES_KEY_LENGTH=32

# 方式二：使用 RSA 加密（适合需要非对称加密的场景）
# 生成 RSA 密钥对：
#   - Linux/Mac: 
#     openssl genrsa -out private.pem 2048
#     openssl rsa -in private.pem -pubout -out public.pem
#   - Windows: 使用 Git Bash 或 WSL 执行上述命令
# 
# RSA 公钥（PEM 格式，包含 -----BEGIN PUBLIC KEY----- 和 -----END PUBLIC KEY-----）
RSA_PUBLIC_KEY=

# RSA 私钥（PEM 格式，包含 -----BEGIN PRIVATE KEY----- 和 -----END PRIVATE KEY-----）
RSA_PRIVATE_KEY=

# RSA 加密算法（默认: rsa-oaep）
# 可选值：rsa-oaep, rsa-pkcs1-v1_5
RSA_ALGORITHM=rsa-oaep

# 加密适配器类型（默认: aes）
# 如果设置了 AES_KEY，默认使用 aes
# 如果只设置了 RSA_PUBLIC_KEY 和 RSA_PRIVATE_KEY，默认使用 rsa
# 可选值：aes, rsa
ENCRYPTION_ADAPTER=aes

# ==================== 授权配置 ====================

# 是否启用授权管理器（默认: true）
# 如果设置为 false，AuthorizationService 将不可用
AUTHORIZATION_ENABLED=true



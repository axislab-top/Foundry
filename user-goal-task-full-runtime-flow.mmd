flowchart TB
    %% =========================
    %% 0. 用户入口
    %% =========================
    U["用户消息/目标请求"] --> GW["Worker Event Consumer<br/>collaboration.message.received"]
    GW --> COORD["CollaborationCoordinatorListener<br/>入口编排(幂等/防环路/审批短路)"]

    %% =========================
    %% 1. 数据与基础服务
    %% =========================
    subgraph DATA["数据库与基础存储(逻辑视图)"]
      DB_MSG["DB: collaboration_messages / message metadata"]
      DB_ROOM["DB: collaboration_rooms / room mode"]
      DB_MEMBER["DB: collaboration_room_members"]
      DB_TASK["DB: tasks / task_relations / task_events"]
      DB_AGENT["DB: agents / agent_skills / org_nodes"]
      DB_MEM["DB: memory entries / hierarchy index / vectors"]
      REDIS["Redis: conversation state cache / cooldown / locks"]
    end

    subgraph API["API RPC Services (Nest RPC patterns)"]
      API_COLLAB["collaboration.*<br/>rooms/findMain/messages/get/messages/appendAgent/members/add"]
      API_TASK["tasks.*<br/>findAll/create/ceo.delegateToDirector"]
      API_AGENT["agents.*<br/>findAll/findOne/effectiveSkillSnapshots/llmKeyPoolCandidates/bindSkills"]
      API_BILL["billing.*<br/>checkAllowance/modelRouter.resolve/consumption.requested"]
      API_MEM["memory.*<br/>search/search.hierarchy/entries.store/consolidation.request"]
      API_ORG["organization.tree"]
      API_LLMKEY["llmKeys.acquire"]
      API_SKILL["skills.resolveGlobalSkillIdsByNames"]
    end

    %% coordinator读取上下文
    COORD --> API_COLLAB
    API_COLLAB --> DB_MSG
    API_COLLAB --> DB_ROOM
    API_COLLAB --> DB_MEMBER
    COORD --> REDIS

    %% =========================
    %% 2. L1 路由
    %% =========================
    COORD --> PIPE["CollaborationRoomPipeline.run()"]
    PIPE --> CLS["L1: CeoClassifierService"]
    CLS --> ENG["CeoClassifierEngineService<br/>guard + normalize + upgrade"]
    ENG --> COORD_FIX["Coordinator ensureTargetedReplyGoesDirect(兜底)"]
    COORD_FIX --> MODE{"最终 mode"}

    %% 向量快路
    PIPE --> FAST["CeoFastpathService + EmbeddingIntentMatcherService"]
    FAST --> EMB1["向量模型请求 #1<br/>intent embedding + vector similarity"]
    EMB1 --> DB_MEM
    EMB1 --> CLS

    %% =========================
    %% 3. L2 Direct/Discussion
    %% =========================
    MODE -- "direct" --> L2D["L2: DirectCollabReplyService"]
    L2D --> L2D_PREP["构建 prompt + transcript + policy + sanitizer"]
    L2D_PREP --> API_AGENT
    L2D_PREP --> API_COLLAB
    L2D_PREP --> API_MEM
    API_MEM --> DB_MEM
    L2D_PREP --> L2D_CALL1["LLM primary invoke (timeout)"]
    L2D_CALL1 --> L2D_OK{"成功?"}
    L2D_OK -- "是" --> APPEND1["API: collaboration.messages.appendAgent"]
    L2D_OK -- "否" --> L2D_CALL2["LLM fallback invoke (timeout)"]
    L2D_CALL2 --> L2D_OK2{"成功且非空?"}
    L2D_OK2 -- "是" --> APPEND1
    L2D_OK2 -- "否" --> DIAG["DiagnosticFallbackService<br/>safe_fallback appendAgent"]
    DIAG --> APPEND1
    APPEND1 --> DB_MSG

    MODE -- "discussion" --> DISC["DiscussionCollabService / ParallelDiscussionOrchestrator"]
    DISC --> DISC_FAN["并行 agent 讨论 fanout + merge"]
    DISC_FAN --> API_COLLAB
    DISC_FAN --> APPEND2["appendAgent(讨论收敛结果)"]
    APPEND2 --> DB_MSG

    %% =========================
    %% 4. L3 Execution Heavy
    %% =========================
    MODE -- "execution" --> HEAVY["L3: CeoHeavyOrchestratorService"]
    HEAVY --> H_ROUTE{"routeSignal == HEAVY_GRAPH"}
    H_ROUTE -- "否" --> H_DOWN["直接降级 L2 structuredReply"]
    H_ROUTE -- "是" --> H_HYB["Hybrid Planner / LangGraph"]
    H_HYB --> H_TOOLSEL["ToolRegistry 选工具 + skill 路由"]
    H_TOOLSEL --> H_MCP{"是否 MCP Tool?"}
    H_MCP -- "是" --> MCP["MCP Tools 调用<br/>外部系统/文档/浏览器等"]
    H_MCP -- "否" --> SKILL_EXEC["RunnerExecutionClient.executeSkill<br/>执行 skills"]
    SKILL_EXEC --> API_TASK
    SKILL_EXEC --> API_COLLAB
    SKILL_EXEC --> API_MEM
    MCP --> H_HYB
    API_TASK --> DB_TASK
    API_MEM --> DB_MEM
    H_HYB --> H_OK{"超时/失败?"}
    H_OK -- "否" --> H_FINAL["heavy final append + memory consolidation.request"]
    H_FINAL --> API_COLLAB
    H_FINAL --> API_MEM
    H_FINAL --> DB_MSG
    H_OK -- "是" --> H_FB["fallback: breakdown -> light structured (单次幂等降级门)"]
    H_FB --> AUTO

    %% =========================
    %% 5. Autonomous Breakdown & Persist
    %% =========================
    subgraph AUTO["AutonomousOrchestratorService (LangGraph: ingest -> plan -> validatePersist -> summarize -> notify)"]
      A_ING["ingest<br/>dashboard/tasks/org/memory/modelRouter"]
      A_PLAN["plan<br/>single-flight + 429 fail-fast cooldown + backoff budget"]
      A_TASK["validatePersist<br/>deterministic idempotency key + create/delegate"]
      A_SUM["summarize"]
      A_NOTI["notify"]
      A_ING --> A_PLAN --> A_TASK --> A_SUM --> A_NOTI
    end

    H_FB --> A_ING
    A_ING --> API_TASK
    A_ING --> API_ORG
    A_ING --> API_MEM
    A_ING --> API_BILL
    A_ING --> API_AGENT
    A_ING --> API_LLMKEY
    A_ING --> DB_TASK
    A_ING --> DB_AGENT
    A_ING --> DB_MEM

    A_ING --> EMB2["向量模型请求 #2<br/>memory/search.hierarchy embedding/rerank(按策略触发)"]
    EMB2 --> DB_MEM
    EMB2 --> A_PLAN

    A_PLAN --> PLAN_OK{"plan 成功?"}
    PLAN_OK -- "否" --> SOFT["soft-failure path<br/>可读降级 + (必要时) HITL"]
    PLAN_OK -- "是" --> A_TASK
    SOFT --> A_SUM

    A_TASK --> API_TASK
    API_TASK --> DB_TASK
    A_TASK --> API_COLLAB
    API_COLLAB --> DB_MEMBER
    A_NOTI --> API_COLLAB
    A_NOTI --> DB_MSG
    A_NOTI --> API_BILL

    %% =========================
    %% 6. Skills/MCP 详细入口
    %% =========================
    COORD --> SKILL_CTX["skills 上下文装配"]
    SKILL_CTX --> API_AGENT
    API_AGENT --> DB_AGENT
    SKILL_CTX --> API_SKILL
    API_SKILL --> DB_AGENT
    SKILL_CTX --> TOOL_REG["ToolRegistry.setAgentTools / assertMcpToolBound"]
    TOOL_REG --> H_TOOLSEL

    %% =========================
    %% 7. 队列与 admission control
    %% =========================
    subgraph QUEUE["Queue/Resilience 路径"]
      Q1["CeoInteractiveQueueService<br/>dedicated queue"]
      Q2["fallback shared queue"]
      Q3["admission control + breaker/cooldown + max inflight"]
    end
    L2D --> Q1
    HEAVY --> Q1
    Q1 --> Q2
    Q2 --> Q3

    %% =========================
    %% 8. 可观测性
    %% =========================
    subgraph OBS["Monitoring + Structured Logs"]
      M1["collab-llm-trace / autonomous-trace<br/>companyId/traceId/reason/stage/elapsedMs"]
      M2["metrics<br/>ceo_plan_rate_limit_total<br/>ceo_plan_failfast_total<br/>collab_fallback_stage_total<br/>collab_route_transition_total"]
    end
    COORD --> M1
    PIPE --> M1
    L2D --> M1
    HEAVY --> M1
    AUTO --> M1
    Q3 --> M1
    M1 --> M2

    %% =========================
    %% 9. 终态
    %% =========================
    APPEND1 --> OUT["用户看到最终消息/任务推进状态"]
    APPEND2 --> OUT
    H_FINAL --> OUT
    A_NOTI --> OUT




# Leave unset in local dev: API calls use /api via Vite proxy.
# Set for production build or `vite preview`, e.g. http://localhost:3002
# VITE_API_BASE_URL=http://localhost:3002

# Optional: gateway URL for the dev proxy (default http://127.0.0.1:3002)
# VITE_API_PROXY_TARGET=http://127.0.0.1:3002

# WebSocket URL for collaboration features (default ws://localhost:3002/ws)
# VITE_WS_URL=ws://localhost:3002/ws

# Phone / other LAN devices: run `pnpm dev:lan`, open http://<wlan-ip>:5173/
# On the dev PC, keep using http://localhost:5173/
# Diagnostics: pnpm lan:check

# 新建公司高级向导（默认开启；设为 false 关闭）
# VITE_ENABLE_COMPANY_WIZARD=false

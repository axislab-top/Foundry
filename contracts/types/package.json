{
  "name": "@contracts/types",
  "version": "1.0.0",
  "description": "服务间共享类型定义",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "default": "./dist/index.js"
    },
    "./collab-redis-keys": {
      "types": "./dist/collab-redis-keys.d.ts",
      "import": "./dist/collab-redis-keys.js",
      "default": "./dist/collab-redis-keys.js"
    },
    "./daily-brief": {
      "types": "./dist/daily-brief.d.ts",
      "import": "./dist/daily-brief.js",
      "default": "./dist/daily-brief.js"
    }
  },
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch",
    "clean": "rimraf dist",
    "type-check": "tsc --noEmit"
  },
  "keywords": ["contracts", "types", "typescript"],
  "author": "",
  "license": "ISC",
  "packageManager": "pnpm@10.27.0",
  "files": [
    "dist",
    "*.ts"
  ],
  "devDependencies": {
    "typescript": "^5.3.3"
  },
  "dependencies": {
    "@foundry/contracts": "workspace:*"
  }
}


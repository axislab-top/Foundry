flowchart TD
  U[Human Message] --> P[Pipeline handleRunExecution]
  P --> FG{WORKER_L3_TEMPORAL_V1 && rollout hit}
  FG -->|no| LEG[Legacy Redis/StateMachine path]
  FG -->|yes| ST[Starter startWorkflow ceo-heavy:${routingRootMessageId}]

  ST --> RW[CeoHeavyRootWorkflow]
  RW --> A1[planningActivity]
  A1 --> AG{Needs approval?}
  AG -->|yes| AP[requestHumanApprovalActivity + wait humanApprovalSignal]
  AP -->|reject| BC[budgetExceeded/partial compensation]
  AG -->|no| A2[splittingActivity adaptive timeout]
  AP -->|approve| A2

  A2 --> A3[distributeActivity]
  A3 --> C0[startChild departmentSubWorkflow x N]
  C0 --> S1[departmentPartialUpdateSignal]
  C0 --> S2[departmentCompleteSignal]
  S1 --> SP[publishDepartmentPartialUpdateActivity]
  S2 --> SC[publishDepartmentCompleteActivity]
  RW --> WC[waitCondition all complete or timeout]
  WC -->|timeout| PC[partialMergeCompensationActivity + L2 forceVisible]
  WC -->|all done| M[mergingActivity]
  M --> MC[memoryConsolidationActivity]
  MC --> OUT[HeavyExecutionOutput finalStage + memoryReferences + executionTrace]

  subgraph Department Child Workflow
    D1[directorPlanningActivity]
    D2[employeeExecuteActivity Promise.all]
    D1 --> D2 --> DS[signal partial/complete to parent]
  end

